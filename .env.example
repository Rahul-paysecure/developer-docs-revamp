# Company SSO (OpenID Connect, RS256)
EDITOR_OIDC_ISSUER=https://identity.example.com
EDITOR_OIDC_CLIENT_ID=
EDITOR_OIDC_CLIENT_SECRET=

# At least one of these contributor allowlists is required.
EDITOR_ALLOWED_EMAIL_DOMAINS=paysecure.net
EDITOR_ALLOWED_GROUPS=

# Use a cryptographically random value of at least 32 characters.
EDITOR_SESSION_SECRET=

# GitHub App installed only on the documentation repository.
EDITOR_GITHUB_APP_ID=
EDITOR_GITHUB_INSTALLATION_ID=
EDITOR_GITHUB_PRIVATE_KEY=
EDITOR_GITHUB_OWNER=
EDITOR_GITHUB_REPO=paysecure-docs-react
EDITOR_GITHUB_BASE_BRANCH=main
EDITOR_GIT_AUTHOR_EMAIL=docs-bot@paysecure.net

# Netlify site subdomain, without .netlify.app.
EDITOR_NETLIFY_SITE_NAME=paysecure-dev-docs-react
